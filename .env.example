# === 공통 (모든 서비스) ===
NODE_ENV=                   # 실행 환경 (development | test | production)
DATABASE_URL=               # PostgreSQL 연결 문자열 (예: postgresql://user:pass@host:5432/db)
AWS_REGION=                 # AWS 리전
AWS_ACCESS_KEY_ID=          # AWS 액세스 키 ID (로컬: test, 프로덕션: IAM 키)
AWS_SECRET_ACCESS_KEY=      # AWS 시크릿 액세스 키 (로컬: test, 프로덕션: IAM 키)
AWS_ENDPOINT_URL=           # AWS 엔드포인트 오버라이드 (로컬 LocalStack: http://localstack:4566)
S3_BUCKET_NAME=             # S3 버킷명 (예: jobs-local)

# === API ===
SQS_SCRIPT_QUEUE_URL=       # script-worker SQS 큐 URL
WEB_ORIGIN=                 # CORS 허용 오리진 (예: http://localhost:3001, 프로덕션: 실제 도메인)
API_INTERNAL_SECRET=        # Web → API 내부 통신 인증 키 (openssl rand -hex 32 로 생성)

# === script-worker ===
GEMINI_API_KEY=             # Google Gemini API 키 (aistudio.google.com에서 발급)
SQS_TTS_QUEUE_URL=          # tts-worker SQS 큐 URL

# === tts-worker ===
SQS_SUBTITLE_QUEUE_URL=     # subtitle-worker SQS 큐 URL
EDGE_TTS_PATH=              # edge-tts 실행 경로 (Docker: edge-tts, Windows: 절대 경로)

# === subtitle-worker ===
SQS_RENDER_QUEUE_URL=       # render-worker SQS 큐 URL
PYTHON_PATH=                # Python 실행 경로 (Docker: python, Windows: 절대 경로)

# === render-worker ===
SQS_UPLOAD_QUEUE_URL=       # upload-worker SQS 큐 URL
FFMPEG_PATH=                # FFmpeg 실행 경로 (Docker: ffmpeg, Windows: 절대 경로)
FFPROBE_PATH=               # ffprobe 실행 경로 (Docker: ffprobe, Windows: 절대 경로)
PEXELS_API_KEY=             # Pexels API 키 (pexels.com/api에서 발급, 배경 이미지 검색용)

# === API + upload-worker 공용 ===
YOUTUBE_CLIENT_ID=          # Google Cloud OAuth2 클라이언트 ID
YOUTUBE_CLIENT_SECRET=      # Google Cloud OAuth2 클라이언트 시크릿
YOUTUBE_REDIRECT_URI=       # OAuth2 리다이렉트 URI
ENCRYPTION_KEY=             # AES-256-GCM 암호화 키 (32bytes hex = 64자)

# === Phase 0 테스트 스크립트 전용 (scripts/tools/test-upload.ts) ===
YOUTUBE_REFRESH_TOKEN=      # YouTube 채널 refresh token (실제 워커는 DB에서 읽음)

# === web (Next.js 대시보드) ===
# apps/web/.env.example 참고 — Next.js는 자신의 디렉토리 .env.local만 읽으므로 별도 관리
