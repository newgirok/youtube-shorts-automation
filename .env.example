# =====================================================================
# youtube-shorts-automation 환경변수 템플릿 (루트 — API + Workers)
# =====================================================================
# 이 파일을 복사해서 .env.local 을 만든 뒤 실제 값을 채워 넣으세요.
# .env.local 은 Git에 커밋하지 마세요 (.gitignore에 의해 제외됨)
# Next.js 대시보드 환경변수는 apps/web/.env.example 참고
# =====================================================================

# ── 실행 환경 ──────────────────────────────────────────────────────────
NODE_ENV=                           # development | production

# ── PostgreSQL (Supabase) ──────────────────────────────────────────────
# Supabase 대시보드 > Settings > Database > Connection String 에서 확인
# Transaction Pooler URL (port 6543) — 런타임 연결 전용 (?connection_limit=1 필수)
DATABASE_URL=
# Session Pooler URL (port 5432) — prisma migrate 전용 직접 연결
DIRECT_URL=

# ── AWS ───────────────────────────────────────────────────────────────
# 로컬 개발: LocalStack 더미 키(test/test) + AWS_ENDPOINT_URL=http://localhost:4566
# 프로덕션:  ~/.aws/credentials 에 저장된 IAM 액세스 키를 terraform/awscli가 자동 참조
#           이 파일에 프로덕션 키를 직접 기입하지 마세요
AWS_REGION=                         # 예: ap-northeast-2
AWS_ACCESS_KEY_ID=                  # 로컬: test  |  프로덕션: AKIA... (IAM 액세스 키 ID)
AWS_SECRET_ACCESS_KEY=              # 로컬: test  |  프로덕션: IAM 시크릿 액세스 키
AWS_ENDPOINT_URL=                   # 로컬: http://localhost:4566  |  프로덕션: 값 없음(미설정)

# ── S3 ────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=                     # 로컬: jobs-local  |  프로덕션: jobs-prod-{AWS계정ID}

# ── API 서버 (apps/api) ────────────────────────────────────────────────
SQS_SCRIPT_QUEUE_URL=               # 로컬: http://localhost:4566/000000000000/script-queue
WEB_ORIGIN=                         # CORS 허용 오리진  |  로컬: http://localhost:3001
# Web → API 내부 인증키. openssl rand -hex 32 로 생성
# apps/web/.env.local 의 NEXT_PUBLIC_API_SECRET 와 반드시 동일 값 사용
API_INTERNAL_SECRET=

# ── script-worker (Lambda) ────────────────────────────────────────────
GEMINI_API_KEY=                     # Google AI Studio (aistudio.google.com) > API 키
SQS_TTS_QUEUE_URL=                  # 로컬: http://localhost:4566/000000000000/tts-queue

# ── tts-worker (Lambda) ───────────────────────────────────────────────
SQS_SUBTITLE_QUEUE_URL=             # 로컬: http://localhost:4566/000000000000/subtitle-queue
EDGE_TTS_PATH=                      # Docker: edge-tts  |  Windows: 절대경로 (`where edge-tts`)

# ── subtitle-worker (ECS Fargate) ─────────────────────────────────────
SQS_RENDER_QUEUE_URL=               # 로컬: http://localhost:4566/000000000000/render-queue
PYTHON_PATH=                        # Docker: python  |  Windows: 절대경로 (`where python`)

# ── render-worker (ECS Fargate) ───────────────────────────────────────
SQS_UPLOAD_QUEUE_URL=               # 로컬: http://localhost:4566/000000000000/upload-queue
FFMPEG_PATH=                        # Docker: ffmpeg   |  Windows: 절대경로 (`where ffmpeg`)
FFPROBE_PATH=                       # Docker: ffprobe  |  Windows: 절대경로 (`where ffprobe`)
PEXELS_API_KEY=                     # pexels.com/api > 무료 API 키 발급 (배경 영상 검색용)

# ── YouTube OAuth2 (API + upload-worker 공용) ─────────────────────────
# Google Cloud Console > 사용자 인증 정보 > OAuth 2.0 클라이언트 ID
# 승인된 리디렉션 URI에 아래 YOUTUBE_REDIRECT_URI 값을 추가해야 함
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=               # 로컬: http://localhost:3000/auth/youtube/callback
# AES-256-GCM 키 — DB에 저장된 refresh_token 암호화/복호화에 사용
# 생성: openssl rand -hex 32  (64자 hex 문자열)
ENCRYPTION_KEY=

# ── 로컬 테스트 스크립트 전용 ─────────────────────────────────────────
# 실제 업로드 워커는 DB 채널 레코드에서 refresh_token을 직접 읽음
# scripts/tools/test-upload.ts 등 로컬 단독 실행 시에만 필요
YOUTUBE_REFRESH_TOKEN=
