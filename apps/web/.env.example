# =====================================================================
# apps/web 환경변수 템플릿 (Next.js 대시보드)
# =====================================================================
# 이 파일을 복사해서 apps/web/.env.local 을 만든 뒤 실제 값을 채워 넣으세요.
# Next.js는 자신의 디렉토리 .env.local 만 읽으므로 루트 .env.local 과 별도 관리합니다.
# =====================================================================

# ── NextAuth v5 인증 시크릿 ───────────────────────────────────────────
# 생성: openssl rand -base64 32
# AUTH_SECRET 과 NEXTAUTH_SECRET 은 동일 값으로 설정 (v4 호환)
AUTH_SECRET=
NEXTAUTH_SECRET=

# ── URL 설정 ──────────────────────────────────────────────────────────
# 로컬: http://localhost:3001  |  프로덕션: https://your-domain.com
NEXTAUTH_URL=
AUTH_URL=                           # NEXTAUTH_URL 과 동일 값

# ── NestJS API 연동 ───────────────────────────────────────────────────
# 로컬: http://localhost:3000  |  프로덕션: https://api.your-domain.com
NEXT_PUBLIC_API_URL=
# 루트 .env.local 의 API_INTERNAL_SECRET 와 반드시 동일 값 사용
NEXT_PUBLIC_API_SECRET=

# ── Google OAuth2 ─────────────────────────────────────────────────────
# 루트 .env.local 의 YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET 와 동일 OAuth 클라이언트 재사용
# Google Cloud Console > 승인된 리디렉션 URI에 {NEXTAUTH_URL}/api/auth/callback/google 추가 필요
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
