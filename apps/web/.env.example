# apps/web/.env.local 템플릿
# Next.js는 자신의 디렉토리 .env.local만 읽으므로 루트 .env.local과 별도 관리한다.

# NextAuth v5 서명 시크릿 (openssl rand -base64 32)
AUTH_SECRET=

# NextAuth v4 호환용 — AUTH_SECRET과 동일 값으로 설정
NEXTAUTH_SECRET=

# Next.js 앱 주소 (예: http://localhost:3001)
NEXTAUTH_URL=
AUTH_URL=

# NestJS API 서버 주소 (예: http://localhost:3000)
NEXT_PUBLIC_API_URL=

# Google OAuth2 클라이언트 ID — 루트 .env.local의 YOUTUBE_CLIENT_ID와 동일 클라이언트 재사용
GOOGLE_CLIENT_ID=

# Google OAuth2 클라이언트 시크릿 — 루트 .env.local의 YOUTUBE_CLIENT_SECRET와 동일
GOOGLE_CLIENT_SECRET=
