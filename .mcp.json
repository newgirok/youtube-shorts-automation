{
  "mcpServers": {
    "shrimp-task-manager": {
      "command": "npx",
      "args": ["-y", "@cjo4m06/mcp-shrimp-task-manager"],
      "env": {
        "DATA_DIR": "${workspaceFolder}/.shrimp-data",
        "RULES_FILE_PATH": "${workspaceFolder}/shrimp-rules.md"
      },
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--output-dir", ".playwright-mcp"],
      "type": "stdio"
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest"],
      "type": "stdio",
      "env": {
        "SUPABASE_ACCESS_TOKEN": ""
      }
    },
    "terraform": {
      "command": "npx",
      "args": ["-y", "@awslabs/terraform-mcp-server@latest"],
      "type": "stdio"
    },
    "aws-serverless": {
      "command": "npx",
      "args": ["-y", "@awslabs/aws-serverless-mcp-server@latest"],
      "type": "stdio",
      "env": {
        "AWS_REGION": "ap-northeast-2"
      }
    },
    "sentry": {
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server@latest"],
      "type": "stdio",
      "env": {
        "SENTRY_AUTH_TOKEN": ""
      }
    }
  }
}
