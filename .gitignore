# 환경변수
.env
.env.*
!.env.example
!**/.env.example

# 의존성
node_modules/
.pnpm-store/

# 빌드 결과
dist/
packages/**/dist
.turbo/
**/.turbo/
*.tsbuildinfo

# 테스트
coverage/
/test-results/

# 테스트 출력
scripts/output/
scripts/output_removed/
scripts/tools/output/

# 폰트 임시 파일 (TTF 파일은 유지, zip/extracted만 제외)
scripts/fonts/extracted/
scripts/fonts/*.zip

# Playwright MCP 임시 파일
.playwright-mcp/

# Shrimp Task Manager 데이터
.shrimp-data/

# 미디어 파일 (용량 큰 바이너리)
public/bg.mp4
**/public/bg.mp4

# 루트 스크린샷 (Playwright 임시 캡처)
/*.png
/*.jpg

# Next.js
.next/
out/

# 보안
*.pem

# Claude Code 로컬 오버라이드 (팀 공유 settings.json과 분리)
**/.claude/settings.local.json

# MCP 로그
.mcp.log

# agentmemory (iii 엔진이 CWD 기준으로 생성하는 런타임 데이터)
/data/

# Terraform 상태 파일 (민감정보 포함 — S3 remote backend 전환 전까지 로컬 보관)
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars

# OS
.DS_Store
Thumbs.db

# Serverless Framework 배포 아티팩트
**/.serverless/

# Lambda Layer 빌드 아티팩트
infra/lambda-layers/edge-tts-build/
infra/lambda-layers/ffprobe-build/
infra/lambda-layers/*.zip

# esbuild 캐시
**/.esbuild/

# 인프라 임시 파일
infra/temp-*.json

# 루트 임시 파일 (확장자 없는 스크린샷 등)
/supabase-signup
